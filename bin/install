#!/usr/bin/env bash
# Symlink this skill into ~/.claude/skills/story-writer so Claude Code picks it up.
# Idempotent: reports current state, refuses to overwrite a non-symlink without --force.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="${HOME}/.claude/skills"
LINK_PATH="${SKILLS_DIR}/story-writer"
FORCE="${1:-}"

if [[ ! -f "${REPO_ROOT}/SKILL.md" ]]; then
  echo "ERROR: ${REPO_ROOT}/SKILL.md not found — is this the right repo?" >&2
  exit 1
fi

mkdir -p "${SKILLS_DIR}"

if [[ -L "${LINK_PATH}" ]]; then
  current="$(readlink "${LINK_PATH}")"
  if [[ "${current}" == "${REPO_ROOT}" ]]; then
    echo "Already installed: ${LINK_PATH} -> ${current}"
    exit 0
  fi
  echo "Replacing existing symlink: ${LINK_PATH} -> ${current}"
  rm "${LINK_PATH}"
elif [[ -e "${LINK_PATH}" ]]; then
  if [[ "${FORCE}" != "--force" ]]; then
    echo "ERROR: ${LINK_PATH} exists and is not a symlink. Re-run with --force to replace it." >&2
    exit 1
  fi
  echo "Removing non-symlink at ${LINK_PATH} (--force)"
  rm -rf "${LINK_PATH}"
fi

ln -s "${REPO_ROOT}" "${LINK_PATH}"
echo "Installed: ${LINK_PATH} -> ${REPO_ROOT}"
echo "Restart Claude Code (or start a new session) to pick up the skill."
